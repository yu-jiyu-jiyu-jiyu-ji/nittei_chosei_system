# Firebase / Firestore 接続用
# サービスアカウント JSON キーファイルのパスを指定してください。
# 相対パス（app.py からの相対）または絶対パスが使えます。
# 例（絶対パス）: E:\cursor\01_日程調整システム\nittei_chosei_system\schedule-adjustment-c32f7-firebase-adminsdk-fbsvc-feee30831f.json
# 例（相対パス）: schedule-adjustment-c32f7-firebase-adminsdk-fbsvc-feee30831f.json

GOOGLE_APPLICATION_CREDENTIALS=schedule-adjustment-c32f7-firebase-adminsdk-fbsvc-feee30831f.json

# --- Google Calendar OAuth（職人の個人 Gmail 連携）---
# 【Console 側】Google Auth プラットフォーム → データアクセス で次のスコープを追加すること
#   https://www.googleapis.com/auth/calendar.events
# （空き検索の読取と、候補「決定」時の予定登録の両方に必要。readonly のみだと検索は動いても登録で 403 になる）
# （手動追加のテキスト欄に貼り付けて「更新」でも可。一覧が空のままだとカレンダー連携が失敗します）
# 【Console 側】クライアントは「Google Auth プラットフォーム → クライアント」でウェブアプリを作成
# （Google マップの「鍵と認証情報」だけでは OAuth クライアントは作れません）
# リダイレクト URI はブラウザの URL と完全一致（例: Streamlit 既定ポート）
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8501/oauth_calendar_return
# 本番（Render 等）の例（Console の「承認済みのリダイレクト URI」にも同じ1行を必ず追加）:
# GOOGLE_OAUTH_REDIRECT_URI=https://YOUR-SERVICE.onrender.com/oauth_calendar_return
# ※ redirect_uri_mismatch は「Console に未登録」か「この値と違う URL で認可しようとした」時に出ます。
# GOOGLE_OAUTH_CLIENT_ID=
# （例）157240209490-xxxxxxxx.apps.googleusercontent.com のように「数字-」で始まる全体をコピーすること
# GOOGLE_OAUTH_CLIENT_SECRET=
# invalid_client のときは Console のクライアント ID をコピペし直す（0 と O、1 と l を取り違えないこと）

# --- 車両用 Google カレンダー（任意・フォールバック）---
# 共通設定の「車用アカウントで Google 連携」で Firestore に保存すれば .env は不要
# GOOGLE_VEHICLE_CALENDAR_TOKEN_JSON=E:\path\to\vehicle_token.json
# GOOGLE_VEHICLE_CALENDAR_REFRESH_TOKEN=

# --- Google Maps（移動時間・拠点戻り）---
# 【Console 側】Google マップ プラットフォーム → 鍵と認証情報 → 「認証情報を作成」→ API キー
# 作成後「キーを編集」→ API の制限で「Distance Matrix API」のみに限定（推奨）
# 課金アカウントがプロジェクトにリンクされている必要があります
# GOOGLE_MAPS_API_KEY=

# --- メール送信（OAuth 案内リンクを職人・車両担当へ送る）---
# Gmail の場合: Google アカウント → セキュリティ → 2 段階認証 → アプリ パスワード
# その他: 利用中のメールサーバの SMTP 設定に合わせる
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-address@gmail.com
# SMTP_PASSWORD=アプリパスワードまたはSMTPパスワード
# 差出人表示（未設定時は SMTP_USER）
# SMTP_FROM=日程調整システム <your-address@gmail.com>
# 587 で STARTTLS を使わない場合のみ 0
# SMTP_USE_TLS=1
# ポート 465 のみ SMTP_SSL（SMTP_USE_TLS は 465 では無視され SSL 接続になります）
